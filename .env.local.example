# Environment variables - Copy to .env.local and fill in your values

# ================== DATABASE ==================
DATABASE_URL="postgresql://ppdb_user:ppdb_password@localhost:5432/ppdb_db"

# ================== NEXTAUTH ==================
NEXTAUTH_SECRET="ppdb-secret-key-change-in-production-$(date +%s)"
NEXTAUTH_URL="http://localhost:3000"

# ================== OAUTH PROVIDERS (Optional) ==================
GITHUB_ID=""
GITHUB_SECRET=""
GOOGLE_ID=""
GOOGLE_SECRET=""

# ================== EXTERNAL SERVICES ==================
# Email sending
RESEND_API_KEY=""

# Maps & Geolocation
GOOGLE_MAPS_API_KEY=""
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# File storage (if using cloud)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET=""
AWS_REGION="ap-southeast-1"

# ================== APP CONFIG ==================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
